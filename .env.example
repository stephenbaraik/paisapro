# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Groq (primary LLM — fast, free tier)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (fallback LLM — generous free tier)
GEMINI_API_KEY=your_gemini_api_key

# Alpha Vantage (Indian market data fallback)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key

# App
APP_ENV=development
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# Pipeline — runs daily after market close (6pm IST = 12:30 UTC)
PIPELINE_SCHEDULE_CRON=0 18 * * 1-5

# ML model persistence — RF classifiers stored as PKL files (train once per day)
# Default: ./models/ next to backend/. On HF Spaces use: /data/models
# MODEL_STORE_DIR=/data/models
